{
  "name": "veritas",
  "displayName": "Veritas — Truth, Risk, Continuity, Learning",
  "description": "A guardrail layer for AI-assisted coding. Three personas (Skeptic, Sentinel, Archivist), six modules, and a persistent .veritas/ state directory. Grounds claims in real code before asserting, gates risky actions by blast radius and reversibility, produces canonical handoffs, captures non-obvious lessons, and carries state across sessions.",
  "version": "0.2.0",
  "author": "TuongHuy0603",
  "license": "MIT",
  "repository": "https://github.com/TuongHuy0603/veritas",
  "keywords": [
    "ai-skill",
    "guardrails",
    "hallucination",
    "verification",
    "risk-management",
    "session-handoff",
    "postmortem",
    "grounding",
    "persona",
    "context-persistence"
  ],
  "platforms": [
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "codex",
    "gemini",
    "continue",
    "roocode",
    "kilocode",
    "opencode",
    "trae",
    "warp",
    "kiro"
  ],
  "install": "npx veritas-cli init --ai {{platform}}",
  "entrypoint": "src/veritas/SKILL.md",
  "personas": [
    "src/veritas/personas/skeptic.md",
    "src/veritas/personas/sentinel.md",
    "src/veritas/personas/archivist.md"
  ],
  "modules": [
    "src/veritas/modules/ground-check.md",
    "src/veritas/modules/blast-radius.md",
    "src/veritas/modules/handoff.md",
    "src/veritas/modules/postmortem.md",
    "src/veritas/modules/persona.md",
    "src/veritas/modules/ledger.md"
  ],
  "state_directory": ".veritas"
}
