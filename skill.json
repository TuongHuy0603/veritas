{
  "name": "veritas",
  "displayName": "Veritas — Umbrella Builder & Guardrail",
  "description": "A five-pillar builder and guardrail for AI-assisted software work. Plan features, design UIs, execute phases, verify with TDD, and gate risky actions — with shared .veritas/ state (provenance DAG, hash-chained action log, canonical handoff, decision journal) across every pillar.",
  "version": "1.0.2",
  "author": "TuongHuy0603",
  "license": "MIT",
  "repository": "https://github.com/TuongHuy0603/veritas",
  "homepage": "https://github.com/TuongHuy0603/veritas",
  "keywords": [
    "ai-skill",
    "builder",
    "guardrails",
    "planning",
    "design-system",
    "tdd",
    "systematic-debugging",
    "risk-scoring",
    "hash-chained-audit",
    "provenance-dag",
    "session-handoff",
    "claude-code",
    "cursor",
    "windsurf",
    "copilot"
  ],
  "platforms": [
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "codex",
    "gemini",
    "continue",
    "roocode",
    "kilocode",
    "opencode",
    "trae",
    "warp",
    "kiro"
  ],
  "install": "npx veritas-cli init --ai {{platform}}",
  "entrypoint": "src/veritas/SKILL.md",
  "pillars": [
    "src/veritas/pillars/plan.md",
    "src/veritas/pillars/design.md",
    "src/veritas/pillars/execute.md",
    "src/veritas/pillars/verify.md",
    "src/veritas/pillars/guardrail.md"
  ],
  "roles": [
    "src/veritas/personas/verifier.md",
    "src/veritas/personas/risk-guard.md",
    "src/veritas/personas/session-recorder.md"
  ],
  "modules": [
    "src/veritas/modules/verify-claim.md",
    "src/veritas/modules/assess-risk.md",
    "src/veritas/modules/save-session.md",
    "src/veritas/modules/record-lesson.md",
    "src/veritas/modules/route-role.md",
    "src/veritas/modules/track-state.md"
  ],
  "commands": [
    "commands/plan.md",
    "commands/design.md",
    "commands/execute.md",
    "commands/verify.md",
    "commands/gate.md",
    "commands/ground.md",
    "commands/handoff.md",
    "commands/resume.md"
  ],
  "state_directory": ".veritas"
}
